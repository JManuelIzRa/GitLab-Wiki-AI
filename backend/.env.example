# Copia este archivo a .env y completa tus valores

# --- LLM de chat / generación del wiki (servidor OpenAI-compatible local) ---
# Ej. llama.cpp server, vLLM, LM Studio, text-generation-webui en modo OpenAI, etc.
OPENAI_URL=http://localhost:8000/
OPENAI_CHAT_MODEL=qwen2.5-3b-instruct-q4_k_m.gguf
# Algunos servidores locales exigen un valor no vacío aunque no validen la key realmente.
OPENAI_API_KEY=not-needed

# --- Embeddings (servicio propio, contrato OpenAI: {input, model} -> {data:[{embedding}]}) ---
EMBEDDING_URL=http://localhost:8080/embed
EMBEDDING_DIMENSIONS=384

# --- Qdrant (vector store para RAG sobre el código indexado) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Prefijo de las colecciones; se sufija con el id del repositorio (ej. deepwiki_repo_3)
QDRANT_COLLECTION_PREFIX=deepwiki_repo_

# --- Base de datos ---
DATABASE_URL=sqlite+aiosqlite:///./deepwiki.db

# --- Indexado y generación ---
MAX_FILES_TO_INDEX=400
MAX_FILE_SIZE_BYTES=200000
# Presupuesto de contexto por llamada al LLM. Recortado a propósito: un modelo local
# 3B cuantizado degrada mucho con prompts largos, a diferencia de un modelo grande en la nube.
MAX_CHARS_PER_AI_CALL=12000
MAX_CHAT_TOKENS=1200

# --- Chunking de código para RAG ---
CHUNK_MAX_CHARS=1500
CHUNK_OVERLAP_CHARS=200
RAG_TOP_K=6

# CORS: orígenes permitidos para el frontend, separados por coma si se sobreescribe vía env
# Por defecto permite todos los orígenes (*) para facilitar desarrollo local

# --- Internacionalización ---
# Código ISO del idioma en que el LLM debe generar el wiki. Soportado: "es" (español), "en" (English).
# Para otros idiomas, la instrucción de idioma se inyecta en el system prompt pero los prompts de usuario
# siguen en inglés (modelos capaces en la nube los seguirán igualmente).
WIKI_LANGUAGE=es

# --- Webhooks de GitLab ---
# Token secreto que GitLab enviará en la cabecera X-Gitlab-Token. Deja vacío para deshabilitar la validación.
GITLAB_WEBHOOK_SECRET=
# PAT con scope read_api + read_repository usado para re-indexar repos disparados por webhook.
# Si está vacío, los webhooks solo se registran pero no disparan re-indexado automático.
GITLAB_DEFAULT_TOKEN=

# --- Rate limiting ---
# Máximo de jobs de indexado nuevos por IP (formato: "N/period", ej. "5/minute", "20/hour")
RATE_LIMIT_INDEX=5/minute
# Máximo de peticiones de chat por IP
RATE_LIMIT_CHAT=30/minute
